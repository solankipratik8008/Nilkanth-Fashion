rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      // Admin can update anything; users can respond to changes OR cancel pre-production orders
      allow update: if isAdmin() ||
        (isAuthenticated() &&
         resource.data.userId == request.auth.uid &&
         (
           // Case 1: Responding to admin suggested changes
           ((resource.data.status == 'changes-suggested' || resource.data.status == 'awaiting-confirmation') &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'userResponse', 'updatedAt']) &&
            (request.resource.data.status == 'user-confirmed' || request.resource.data.status == 'cancelled' || request.resource.data.status == 'waiting-for-fabric'))
           ||
           // Case 2: Cancelling a pre-production order
           (request.resource.data.status == 'cancelled' &&
            resource.data.status in ['pending-review', 'awaiting-confirmation', 'user-confirmed', 'waiting-for-fabric'] &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledByUser', 'cancelReason', 'cancelledAt', 'updatedAt']))
         ));
      allow delete: if isAdmin();
    }

    // Custom Design Requests
    match /customDesignRequests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      // Admin can update anything; users can respond to suggestions OR mark order-placed
      allow update: if isAdmin() ||
        (isAuthenticated() &&
         resource.data.userId == request.auth.uid &&
         (
           // Case 1: Responding to admin suggestions (awaiting-confirmation)
           (resource.data.status == 'awaiting-confirmation' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'userResponse', 'updatedAt']) &&
            (request.resource.data.status == 'user-confirmed' || request.resource.data.status == 'cancelled' || request.resource.data.status == 'waiting-for-fabric'))
           ||
           // Case 2: Placing an order from approved request
           (resource.data.status == 'approved' &&
            request.resource.data.status == 'order-placed' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'orderId', 'updatedAt']))
         ));
      allow delete: if isAdmin();
    }

    // Designs (public read, admin write)
    match /designs/{designId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Contact Messages
    match /contactMessages/{messageId} {
      allow create: if true; // Anyone can send contact message
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Site Analytics (public write for page views, admin read)
    match /siteAnalytics/{docId} {
      allow read: if isAdmin();
      allow write: if true; // Page views tracked by all visitors
    }

    // Site Settings (admin only write, public read)
    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Dynamic Pages (public read, admin write)
    match /dynamicPages/{pageId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
